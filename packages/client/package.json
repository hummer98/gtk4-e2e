{
  "name": "gtk4-e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TS SDK + CLI for the gtk4-e2e in-process server.",
  "bin": {
    "gtk4-e2e": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "biome lint .",
    "fmt:check": "biome format .",
    "test": "bun test",
    "gen:types": "cargo run -p gtk4-e2e-server --example gen-schemas --features e2e && bun scripts/gen-types.ts"
  },
  "devDependencies": {
    "@types/bun": "^1",
    "@types/pngjs": "^6",
    "json-schema-to-typescript": "^15"
  },
  "dependencies": {
    "pixelmatch": "^7",
    "pngjs": "^7"
  }
}
