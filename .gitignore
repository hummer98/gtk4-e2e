# Rust
target/
**/*.rs.bk
Cargo.lock

# Node / Bun
# bun.lock を SSOT とし、npm 由来の package-lock.json はコミットしない
node_modules/
.bun/
dist/
*.log
package-lock.json

# Generated types (Rust → TS codegen output, must not be hand-edited)
**/*.gen.ts
**/*.gen.d.ts

# JSON Schemas under packages/server/proto/schemas/ are committed SSOT artifacts
# generated by `cargo run --example gen-schemas --features e2e` (see ADR-0002).
# CI uses `git diff --exit-code packages/server/proto/schemas/` for stale check.

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Test artifacts
test-results/
recordings/
screenshots/

# Env
.env
.env.local
.env.*.local

# TypeScript incremental
*.tsbuildinfo

# Coverage
coverage/

# Bun runtime tmp
.bun-cache/
